# ─── Azure Resource Identifiers ────────────────────────────────────────────────
# No CLIENT_ID / CLIENT_SECRET / TENANT_ID needed!
# Auth is handled automatically:
#   - Local dev  : run `az login` once in your terminal
#   - Kubernetes : use AKS Workload Identity (assign managed identity to the pod)

SUBSCRIPTION_ID=your-subscription-id-here
RESOURCE_GROUP=your-resource-group-name

# ─── Azure API Center ──────────────────────────────────────────────────────────
API_CENTER_SERVICE_NAME=your-api-center-service-name

# ─── Azure API Management ──────────────────────────────────────────────────────
APIM_SERVICE_NAME=your-apim-service-name

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
