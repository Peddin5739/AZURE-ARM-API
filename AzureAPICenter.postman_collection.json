                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"apiId\": \"payments-api\",\n  \"title\": \"Payments API\",\n  \"description\": \"Handles all payment flows\",\n  \"kind\": \"rest\",\n  \"lifecycleStage\": \"development\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/apicenter/onboard",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
