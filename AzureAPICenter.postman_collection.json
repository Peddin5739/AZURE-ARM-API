                            ]
                        },
                        "description": "Registers an API in Azure API Center catalog.\n\nkind options: rest | graphql | grpc | soap | webhook | websocket\nlifecycleStage options: design | development | testing | preview | production"
                    }
                },
                {
                    "name": "Delete API",
                    "request": {
                        "method": "DELETE",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/apicenter/payments-api",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "apicenter",
                                "payments-api"
                            ]
                        },
                        "description": "Deletes an API from the API Center catalog.\n⚠️ Change 'payments-api' in the URL to the target API ID."
                    }
                }
            ]
        },
        {
            "name": "👤 Azure AD (Graph API)",
            "item": [
                {
                    "name": "Get User Details",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                                    "pm.test('Has user object', () => pm.expect(pm.response.json()).to.have.property('user'));"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"user@yourdomain.com\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/user-details",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "user-details"
                            ]
                        },
                        "description": "Fetches:\n  - User profile (name, job title, department)\n  - Azure AD group memberships\n  - App role assignments"
                    }
                }
            ]
        }
    ]
}