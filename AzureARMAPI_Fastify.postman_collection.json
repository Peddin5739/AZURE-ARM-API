{
    "info": {
        "name": "Azure ARM API — Fastify",
        "_postman_id": "azure-arm-api-fastify-v2",
        "description": "Azure APIM & API Center onboarding via ARM REST API (Fastify + TypeScript)",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
