            "item": [
                {
                    "name": "Full Onboard (6 steps)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/apim/onboard-full",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "apim",
                                "onboard-full"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            },
                            "raw": "{\n  \"apiId\": \"payments-api\",\n  \"displayName\": \"Payments API\",\n  \"path\": \"payments\",\n  \"backendUrl\": \"https://httpbin.org\",\n  \"description\": \"Payment processing API\",\n  \"protocols\": [\"https\"],\n  \"subscriptionRequired\": true,\n  \"namedValues\": [\n    { \"name\": \"backend-url\", \"value\": \"https://httpbin.org\", \"isSecret\": false },\n    { \"name\": \"api-key\", \"value\": \"mysecretkey123\", \"isSecret\": true }\n  ],\n  \"swagger\": \"openapi: 3.0.0\\ninfo:\\n  title: Payments API\\n  version: 1.0.0\\npaths:\\n  /pay:\\n    post:\\n      operationId: makePayment\\n      summary: Make a payment\\n      responses:\\n        '200':\\n          description: Success\",\n  \"apiPolicy\": \"<policies><inbound><rate-limit calls=\\\"100\\\" renewal-period=\\\"60\\\" /><base /></inbound><backend><forward-request /></backend><outbound><base /></outbound><on-error><base /></on-error></policies>\",\n  \"product\": {\n    \"productId\": \"payments-product\",\n    \"displayName\": \"Payments Product\",\n    \"description\": \"Access to Payment APIs\",\n    \"subscriptionRequired\": true,\n    \"state\": \"published\",\n    \"policy\": \"<policies><inbound><base /></inbound><backend><forward-request /></backend><outbound><base /></outbound><on-error><base /></on-error></policies>\"\n  },\n  \"subscription\": {\n    \"subscriptionId\": \"sub-payments-api\",\n    \"displayName\": \"Default Subscription\"\n  }\n}"
                        }
                    }
                },
                {
                    "name": "List APIs",
                    "request": {
